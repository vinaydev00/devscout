{
  "name": "devscout",
  "version": "1.0.0",
  "description": "GitHub Developer Credibility Report Generator",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run build:client",
    "build:client": "cd client && npm run build && cd ..",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "cd client && npm run dev",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "test": "vitest"
  },
  "keywords": ["github", "credibility", "developer-score"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "octokit": "^3.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "typescript": "^5.2.2",
    "tsx": "^3.14.0",
    "eslint": "^8.50.0",
    "concurrently": "^8.2.1",
    "vitest": "^0.34.4"
  }
}
